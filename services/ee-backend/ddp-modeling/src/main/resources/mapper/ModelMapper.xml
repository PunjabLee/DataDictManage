<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    ModelMapper.xml — 模型数据库映射文件
    @layer Infrastructure Layer — infrastructure/persistence/mapper
-->
<mapper namespace="com.datadictmanage.modeling.infrastructure.persistence.mapper.ModelMapper">

    <!-- 结果映射 -->
    <resultMap id="ModelResultMap" type="com.datadictmanage.modeling.infrastructure.persistence.po.ModelPO">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="project_id" property="projectId"/>
        <result column="current_branch_id" property="currentBranchId"/>
        <result column="entities_json" property="entitiesJson"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 根据项目 ID 查询模型列表（按更新时间倒序） -->
    <select id="selectByProjectId" resultMap="ModelResultMap">
        SELECT id, name, description, project_id, current_branch_id,
               entities_json, created_by, created_at, updated_at
        FROM ddm_model
        WHERE project_id = #{projectId}
          AND deleted = 0
        ORDER BY updated_at DESC
    </select>

</mapper>
