{
  "name": "@ddm/canvas-render",
  "version": "1.0.0",
  "description": "DDM Canvas 渲染引擎 — 基于 Canvas 2D API 的数据模型 ER 图渲染器",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "yjs": "^13.6.10",
    "y-websocket": "^1.5.0",
    "rxjs": "^7.8.1"
  },
  "peerDependencies": {
    "@ddm/core-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "sideEffects": false
}
