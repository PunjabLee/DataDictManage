{
  "name": "@ddm/desktop-ce",
  "version": "1.0.0",
  "description": "DDM Desktop CE — Electron + React 桌面端社区版",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ddm/core-engine": "workspace:*",
    "@ddm/canvas-render": "workspace:*",
    "@ddm/db-dialect": "workspace:*",
    "zustand": "^4.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/electron": "^1.6.10",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0",
    "typescript": "^5.4.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "concurrently": "^8.2.0"
  }
}
