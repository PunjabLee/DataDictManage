{
  "name": "@ddm/desktop-ce",
  "version": "1.0.0",
  "description": "DDM Desktop CE — Electron + React 桌面端社区版",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ddm/core-engine": "workspace:*",
    "@ddm/canvas-render": "workspace:*",
    "@ddm/db-dialect": "workspace:*",
    "@ddm/shared-ui": "workspace:*",
    "zustand": "4.5.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.22.0",
    "electron-store": "8.1.0"
  },
  "devDependencies": {
    "electron": "28.2.0",
    "electron-builder": "24.9.1",
    "@types/react": "18.2.55",
    "@types/react-dom": "18.2.19",
    "@types/electron": "1.6.10",
    "@vitejs/plugin-react": "4.2.1",
    "vite": "5.1.0",
    "typescript": "5.4.5",
    "tailwindcss": "3.4.1",
    "autoprefixer": "10.4.17",
    "postcss": "8.4.35",
    "concurrently": "8.2.2"
  }
}
